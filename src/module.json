{
    "id": "barbrawl",
    "title": "Bar Brawl",
    "description": "Fork of Bar Brawl that preserves Adrian Haberecht's original work while adapting resource bar segmentation toward Draw Steel stamina and recovery.",
    "authors": [
        {
            "name": "Adrian Haberecht",
            "url": "https://gitlab.com/woodentavern",
            "discord": "dj_addi"
        },
        {
            "name": "Luthair"
        }
    ],
    "version": "1.9.1",
    "compatibility": {"minimum": "13.341", "verified": "13.351"},
    "esmodules": ["barbrawl.js"],
    "styles": ["styles/attributeHud.css"],
    "languages": [
        {"lang": "de", "name": "Deutsch", "path": "lang/de.json", "flags": {}},
        {"lang": "en", "name": "English", "path": "lang/en.json", "flags": {}},
        {"lang": "ja", "name": "日本語", "path": "lang/ja.json", "flags": {}},
        {"lang": "ko", "name": "한국어", "path": "lang/ko.json", "flags": {}},
        {
            "lang": "pt-BR",
            "name": "Português (Brasil)",
            "path": "lang/pt-BR.json",
            "flags": {}
        },
        {"lang": "pl", "name": "Polski", "path": "lang/pl.json", "flags": {}}
    ],
    "url": "https://github.com/luthair/draw-steel-bar-brawl",
    "manifest": "https://raw.githubusercontent.com/luthair/draw-steel-bar-brawl/master/src/module.json",
    "download": "https://github.com/luthair/draw-steel-bar-brawl/archive/refs/heads/master.zip",
    "license": "https://github.com/luthair/draw-steel-bar-brawl/blob/master/LICENSE",
    "readme": "https://github.com/luthair/draw-steel-bar-brawl/blob/master/README.md",
    "bugs": "https://github.com/luthair/draw-steel-bar-brawl/issues",
    "changelog": "https://github.com/luthair/draw-steel-bar-brawl/blob/master/CHANGELOG.md",
    "flags": {
        "hotReload": {
            "extensions": ["css", "hbs", "json"],
            "paths": ["styles/attributeHud.css", "templates", "lang"]
        }
    }
}